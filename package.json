{
  "name": "studyforge",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "concurrently -n api,web -c blue,green \"npm run dev --workspace=apps/api\" \"npm run dev --workspace=apps/web\"",
    "typecheck": "tsc -b apps/api apps/web packages/shared-types",
    "lint": "eslint .",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "@eslint/js": "^9.7.0",
    "typescript-eslint": "^8.0.0",
    "concurrently": "^8.2.2",
    "eslint": "^9.7.0",
    "prettier": "^3.3.3",
    "typescript": "^5.5.4"
  }
}
